<!--
  Recipe: line-chart
  Description: Time-series line chart. X axis is a date field (rendered at a chosen granularity); Y axis is an aggregated measure.
  Required placeholders:
    {{SHEET_NAME}}
    {{DATASOURCE_NAME}}
    {{DATASOURCE_CAPTION}}
    {{FIELD_X}}            - date field, e.g. "[Order Date]"
    {{FIELD_X_GRANULARITY}}- year|quarter|month|week|day (lowercased)
    {{FIELD_X_PREFIX}}     - yr|qr|mn|wk|dy (Tableau abbreviation)
    {{FIELD_Y}}            - measure field
    {{AGG_Y}}              - aggregate function lowercased
    {{COLOR_PRIMARY}}      - optional hex color
-->
<worksheet name='{{SHEET_NAME}}'>
  <table>
    <view>
      <datasources>
        <datasource caption='{{DATASOURCE_CAPTION}}' name='{{DATASOURCE_NAME}}'/>
      </datasources>
      <datasource-dependencies datasource='{{DATASOURCE_NAME}}'>
        <column-instance column='{{FIELD_X}}' derivation='{{FIELD_X_GRANULARITY_TITLE}}' name='[{{FIELD_X_PREFIX}}:{{FIELD_X_NAME}}:ok]' pivot='key' type='ordinal'/>
        <column-instance column='{{FIELD_Y}}' derivation='{{AGG_Y_TITLE}}' name='[{{AGG_Y}}:{{FIELD_Y_NAME}}:qk]' pivot='key' type='quantitative'/>
      </datasource-dependencies>
      <aggregation value='true'/>
    </view>
    <style/>
    <panes>
      <pane>
        <view>
          <breakdown value='auto'/>
        </view>
        <mark class='Line'/>
        <style>
          <style-rule element='mark'>
            <format attr='mark-color' value='{{COLOR_PRIMARY}}'/>
          </style-rule>
        </style>
      </pane>
    </panes>
    <rows>{{DATASOURCE_NAME}}.[{{AGG_Y}}:{{FIELD_Y_NAME}}:qk]</rows>
    <cols>{{DATASOURCE_NAME}}.[{{FIELD_X_PREFIX}}:{{FIELD_X_NAME}}:ok]</cols>
  </table>
</worksheet>
