# Tableau Cloud credentials shared by publish-to-cloud (Python) and analyze-twbx (TS).
# Copy this file to `.env` and fill in your values. The real `.env` is gitignored.

# Tableau Cloud URL (pod host). Example: https://10ax.online.tableau.com
TABLEAU_SERVER_URL=

# Site content URL (the part after /site/ in the Cloud URL). Empty string means default site.
TABLEAU_SITE_ID=

# Personal Access Token name (configured in Tableau Cloud > My Account Settings)
TABLEAU_PAT_NAME=

# Personal Access Token secret value
TABLEAU_PAT_VALUE=

# Default project to publish into (e.g. "WOW Challenges").
TABLEAU_PROJECT_NAME=WOW Challenges
